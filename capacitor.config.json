{
  "appId": "com.ruleradar.app",
  "appName": "Rule Radar",
  "webDir": "out",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https"
  },
  "ios": {
    "backgroundColor": "#080604",
    "contentInset": "always",
    "preferredContentMode": "mobile",
    "scheme": "RuleRadar"
  },
  "plugins": {
    "StatusBar": { "style": "DARK", "backgroundColor": "#080604" },
    "SplashScreen": {
      "launchShowDuration": 2500,
      "launchAutoHide": true,
      "backgroundColor": "#080604",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    }
  }
}
